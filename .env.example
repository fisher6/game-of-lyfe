# Copy to `.env` and fill in real values (never commit `.env`).

# PostgreSQL — Supabase direct URI from Dashboard → Settings → Database
# Format: postgresql://postgres:PASSWORD@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# Special characters in the password must be URL-encoded (or copy the full URI from Supabase).
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD_HERE@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# On Vercel, prefer Supabase *connection pooler* (often port 6543) if you see "too many connections".

# Auth.js — run: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth (Web application client in Google Cloud Console)
# Authorized redirect URI must include:
#   http://localhost:3000/api/auth/callback/google
# Also add your production URL when you deploy.
#
# Either pair works (use one naming style):
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
#
# After changing .env: stop and run `npm run dev` again.
#
# Use real values — do not leave empty quotes. Auth.js needs a non-empty client ID.

# Demo / QA (deployed only): set to 1 to show "Skip ~10 yrs" on /play. Local `npm run dev` shows it without this.
# NEXT_PUBLIC_GAME_ADMIN_TOOLS=1
