# Copy to `.env` and fill in real values (never commit `.env`).

# PostgreSQL — Supabase direct URI from Dashboard → Settings → Database
# Format: postgresql://postgres:PASSWORD@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# Special characters in the password must be URL-encoded (or copy the full URI from Supabase).
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD_HERE@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# On Vercel, prefer Supabase *connection pooler* (often port 6543) if you see "too many connections".

# Auth.js — run: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth — redirect: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
